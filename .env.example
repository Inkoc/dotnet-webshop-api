# Copy to .env and fill in real values (.env is gitignored).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=webshop

# Must be at least 32 characters.
JWT_SECRET_KEY=change-me-to-a-long-random-secret-min-32-chars

# Admin account seeded on a fresh DB (only if no admin exists yet).
ADMIN_SEED_EMAIL=admin@webshop.local
ADMIN_SEED_PASSWORD=ChangeMe123!
